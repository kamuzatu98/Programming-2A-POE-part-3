<Window x:Class="CybersecurityChatbot.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="720" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="#0E1621" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Shared button look -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2A3B4D"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#0E1621"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII art logo and greeting -->
        <Border Grid.Row="0" Background="#13202E" CornerRadius="10" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LogoText" Grid.Column="0"
                           FontFamily="Consolas" FontSize="11" Foreground="#46D17F"
                           TextWrapping="NoWrap"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                    <TextBlock Text="Cybersecurity Awareness Bot"
                               Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="GreetingText"
                               Text="Helping South African citizens stay safe online."
                               Foreground="#9FB3C8" FontSize="14" Margin="0,4,0,0"/>
                    <TextBlock x:Name="DbStatusText" Text="" Foreground="#E0B341"
                               FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main tabbed area -->
        <TabControl Grid.Row="1" Background="#13202E" BorderThickness="0">

            <!-- CHAT TAB -->
            <TabItem Header="Chat">
                <Grid Margin="10" Background="#0E1621">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0B131C" CornerRadius="8" Padding="6">
                        <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChatPanel" Margin="8"/>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ChatInput" Grid.Column="0" Height="42"
                                 Background="#1B2A39" Foreground="White" BorderThickness="0"
                                 FontSize="14" Padding="12,10" VerticalContentAlignment="Center"
                                 KeyDown="ChatInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send" Width="90" Height="42"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TASKS TAB -->
            <TabItem Header="Tasks">
                <Grid Margin="14" Background="#0E1621">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add task form -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Add a cybersecurity task" Foreground="White"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Title" Foreground="#9FB3C8" Margin="0,4"/>
                        <TextBox x:Name="TaskTitleBox" Background="#1B2A39" Foreground="White"
                                 BorderThickness="0" Padding="8" />
                        <TextBlock Text="Description" Foreground="#9FB3C8" Margin="0,10,0,4"/>
                        <TextBox x:Name="TaskDescBox" Background="#1B2A39" Foreground="White"
                                 BorderThickness="0" Padding="8" Height="70"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                        <TextBlock Text="Reminder (optional)" Foreground="#9FB3C8" Margin="0,10,0,4"/>
                        <DatePicker x:Name="TaskReminderPicker"/>
                        <Button Content="Add Task" Margin="0,14,0,0" Click="AddTask_Click"/>
                    </StackPanel>

                    <!-- Task list -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Your tasks" Foreground="White"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListView x:Name="TaskListView" Grid.Row="1" Background="#0B131C"
                                  Foreground="White" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Title" Width="200" DisplayMemberBinding="{Binding Title}"/>
                                    <GridViewColumn Header="Description" Width="240" DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="Reminder" Width="110" DisplayMemberBinding="{Binding ReminderText}"/>
                                    <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding StatusText}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Mark Completed" Click="CompleteTask_Click"/>
                            <Button Content="Delete" Style="{StaticResource GhostButton}" Click="DeleteTask_Click"/>
                            <Button Content="Refresh" Style="{StaticResource GhostButton}" Click="RefreshTasks_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- QUIZ TAB -->
            <TabItem Header="Quiz">
                <Grid Margin="20" Background="#0E1621">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock x:Name="QuizProgressText" DockPanel.Dock="Left"
                                   Foreground="#9FB3C8" FontSize="14"/>
                        <TextBlock x:Name="QuizScoreText" DockPanel.Dock="Right"
                                   Foreground="#46D17F" FontSize="14" FontWeight="Bold"/>
                    </DockPanel>

                    <TextBlock x:Name="QuizQuestionText" Grid.Row="1" Foreground="White"
                               FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"
                               Margin="0,12,0,16"
                               Text="Press Start to test your cybersecurity knowledge."/>

                    <StackPanel x:Name="QuizOptionsPanel" Grid.Row="2"/>

                    <TextBlock x:Name="QuizFeedbackText" Grid.Row="3" Foreground="#E0B341"
                               FontSize="14" TextWrapping="Wrap" Margin="0,10"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button x:Name="QuizStartButton" Content="Start Quiz" Click="StartQuiz_Click"/>
                        <Button x:Name="QuizNextButton" Content="Next Question"
                                Style="{StaticResource GhostButton}" Click="NextQuestion_Click"
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ACTIVITY LOG TAB -->
            <TabItem Header="Activity Log">
                <Grid Margin="20" Background="#0E1621">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Recent actions taken by the bot"
                               Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ListBox x:Name="ActivityLogList" Grid.Row="1" Background="#0B131C"
                             Foreground="#CFE3F2" BorderThickness="0" FontSize="14"/>
                    <Button Grid.Row="2" Content="Refresh Log" HorizontalAlignment="Left"
                            Margin="0,10,0,0" Click="RefreshLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
